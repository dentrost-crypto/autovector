{
  "name": "autovector",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:car-video": "node scripts/build-car-video.js",
    "content:approve": "node scripts/content/content-approval-agent.js",
    "content:create": "node scripts/content/content-creator-agent.js",
    "content:image": "node scripts/content/image-agent.js",
    "content:pipeline": "npm run content:create && npm run content:review && npm run content:image && npm run publisher:prepare && npm run publisher:vk:draft",
    "content:pipeline:draft": "npm run content:pipeline",
    "content:pipeline:live": "npm run content:create && npm run content:review && npm run content:image && npm run publisher:prepare && npm run publisher:vk:live && npm run publisher:mark-published",
    "content:review": "node scripts/directors/creative-director-agent.js",
    "download-images": "node scripts/download-images.js",
    "post:vk": "node scripts/post-to-vk.js",
    "publisher:prepare": "node scripts/publisher/publisher-agent.js",
    "publisher:mark-published": "node scripts/publisher/publisher-agent.js mark-published",
    "publisher:vk:draft": "node scripts/workers/browser-worker.js AMOS/workflows/vk-publish.workflow.json",
    "publisher:vk:live": "node scripts/workers/browser-worker.js AMOS/workflows/vk-publish-live.workflow.json",
    "trend:scout": "node scripts/intelligence/trend-agent.js",
    "update-rates": "node scripts/update-rates.js",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
